#                /___/
#
# Configuration
shell_integration no-cursor
remember_window_size        no
;initial_window_width        950
;initial_window_height       600
cursor_blink_interval       0.5
cursor_stop_blinking_after  15
scrollback_lines            2000
wheel_scroll_min_lines      1
enable_audio_bell           no
window_padding_width        0
# Will hide the window title from i3 if set to yes
hide_window_decorations     no 
background_opacity          1 
#background_blur 1

dynamic_background_opacity  no
confirm_os_window_close     0

cursor_shape block 
modify_font underline_thickness 100%
modify_font underline_position -1px


cursor_blink_interval .5 
cursor_stop_blinking_after 0

repaint_delay 8
input_delay 0

cursor_trail 3 
cursor_trail_decay 0.1 0.3

cursor_trail_deck 0.5
cursor_trail_start_threshold 0

window_padding_width 5 12 2 12

# cursor #f5e0dc

map ctrl+shift+left neighboring_window left
map ctrl+shift+right neighboring_window right
map ctrl+shift+up neighboring_window up
map ctrl+shift+down neighboring_window down

map ctrl+tab next_tab
map ctrl+` previous_tab
tab_title_template {title}


# BEGIN_KITTY_FONTS
font_family      family="Iosevka Nerd Font"
bold_font        auto
italic_font      auto
bold_italic_font auto
font_size        13
# END_KITTY_FONTS


# BEGIN_KITTY_THEME
# Adapta Nokto Maia
include current-theme.conf
# END_KITTY_THEME
